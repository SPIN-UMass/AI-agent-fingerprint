[Unit]
Description=Agent Scraper - Web Request Fingerprinting
After=network.target

[Service]
Type=simple
ExecStart=/opt/agent-scraper/agent-scraper \
    --https :443 \
    --http :80 \
    --cert /opt/agent-scraper/tls.crt \
    --key /opt/agent-scraper/tls.key \
    --log-dir /opt/agent-scraper/logs \
    --content-dir /opt/agent-scraper/content
Restart=always
RestartSec=5
LimitNOFILE=65535
WorkingDirectory=/opt/agent-scraper

[Install]
WantedBy=multi-user.target
